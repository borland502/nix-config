#!/usr/bin/env bash
# Resolve and ensure the directory SDD uses for its short-lived artifacts:
# task briefs, implementer reports, review packages, and the progress ledger.
# Print the selected directory's absolute path.
#
# Use the working tree only when its SDD path is already ignored. Otherwise,
# use a stable cache path so this helper never changes repository ignore rules.
#
# Single source of truth for the workspace location, so task-brief and
# review-package cannot drift to different directories.
#
# Usage: sdd-workspace
set -euo pipefail

root=$(git rev-parse --show-toplevel)
local_dir="$root/.superpowers/sdd"

if git check-ignore -q "$local_dir/.probe"; then
  dir="$local_dir"
else
  repo=$(printf '%s' "$(basename "$root")" | tr -cs '[:alnum:]._-' '-')
  branch=$(git branch --show-current)
  if [[ -z "$branch" ]]; then
    branch="detached-$(git rev-parse --short HEAD)"
  fi
  branch=$(printf '%s' "$branch" | tr -cs '[:alnum:]._-' '-')
  fingerprint=$(printf '%s' "$root" | cksum | awk '{print $1}')
  dir="${XDG_CACHE_HOME:-$HOME/.cache}/copilot/sdd-${repo}-${branch}-${fingerprint}"
fi

mkdir -p "$dir"
cd "$dir" && pwd -P
