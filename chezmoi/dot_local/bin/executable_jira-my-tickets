#!/bin/zsh
# List open Jira tickets assigned to the current user.
# Delegates auth + base-URL composition to jira-get (Bearer PAT — the Jira
# Data Center instance rejects cloud-style email:token Basic auth).
set -euo pipefail

"${0:A:h}/jira-get" 'search?jql=assignee%3DcurrentUser()%20AND%20statusCategory%20!%3D%20Done%20ORDER%20BY%20rank%20ASC&fields=key,summary,status,priority,issuetype&maxResults=25' |
	jq '.issues[] | {key: .key, summary: .fields.summary, status: .fields.status.name, priority: .fields.priority.name, type: .fields.issuetype.name}'
