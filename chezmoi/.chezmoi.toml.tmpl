{{- /* chezmoi config template — regenerated by `task chezmoi-init` or `chezmoi init --source`. */ -}}
sourceDir = {{ .chezmoi.sourceDir | quote }}
{{- $ageKeyFile := joinPath .chezmoi.homeDir ".config" "sops" "age" "keys.txt" -}}
{{- if stat $ageKeyFile }}
encryption = "age"

[age]
  identity = {{ $ageKeyFile | quote }}
{{- end }}
