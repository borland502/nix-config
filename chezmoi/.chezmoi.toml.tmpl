{{- /* chezmoi config template — used by `chezmoi init` on fresh systems.
       On managed systems (NixOS/Darwin with home-manager) the config file is
       written by the home-manager activation instead. */ -}}
{{- $ageKeyFile := joinPath .chezmoi.homeDir ".config" "sops" "age" "keys.txt" -}}
{{- if stat $ageKeyFile }}
[age]
  identity = {{ $ageKeyFile | quote }}
{{- end }}
