{{- if ne .chezmoi.os "windows" }}
# Source checkouts for borland502 Go CLIs. The companion script
# run_install-go-tools.sh.tmpl builds binaries from these into ~/.local/bin.
#
# chezmoi pulls each repo on first apply, then re-pulls once refreshPeriod
# has elapsed. Run `chezmoi update` (alias for `chezmoi apply --refresh-externals`)
# to force a refresh sooner.
#
# refreshPeriod is set to 720h (~1 month) across all externals.

[".local/src/wordgen"]
    type = "git-repo"
    url = "https://github.com/borland502/wordgen.git"
    refreshPeriod = "720h"
    [".local/src/wordgen".pull]
        args = ["--ff-only"]

[".local/src/gopwgen"]
    type = "git-repo"
    url = "https://github.com/borland502/gopwgen.git"
    refreshPeriod = "720h"
    [".local/src/gopwgen".pull]
        args = ["--ff-only"]

[".local/src/go-sea"]
    type = "git-repo"
    url = "https://github.com/borland502/go-sea.git"
    refreshPeriod = "720h"
    [".local/src/go-sea".pull]
        args = ["--ff-only"]

# AI tooling source checkouts.  These are read-only upstream sources used to
# derive skills/agents/plugins for the curated AI tooling that this repo
# deploys into ~/.config/claude and ~/.config/copilot.  They are *not*
# user-facing dotfiles; downstream tasks/scripts read from these paths and
# emit the curated outputs into the deploy locations.

