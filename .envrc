# Use the Nix flake devShell when Nix is available.
if command -v nix > /dev/null 2>&1; then
  if [[ "$(uname -s)" == "Linux" ]]; then
    use flake ".#go-gui"
  else
    use flake
  fi
else
  # Nix not available: bootstrap Go and go-task into ~/.local.
  _local_bin="$HOME/.local/bin"
  _go_root="$HOME/.local/go"
  mkdir -p "$_local_bin"
  PATH_add "$_go_root/bin"
  PATH_add "$_local_bin"
  PATH_add "$HOME/go/bin"

  # Install go-task if not already present.
  if ! command -v task > /dev/null 2>&1 && ! [[ -x "$_local_bin/task" ]]; then
    log_status "go-task not found; installing to $_local_bin"
    sh -c "$(curl -fsSL https://taskfile.dev/install.sh)" -- -d -b "$_local_bin"
  fi

  # Install Go if not already present.
  if ! [[ -x "$_go_root/bin/go" ]]; then
    _os=$(uname -s | tr '[:upper:]' '[:lower:]')
    _arch=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')
    _ver=$(curl -fsSL "https://go.dev/dl/?mode=json" \
      | python3 -c "import sys,json; print(json.load(sys.stdin)[0]['version'])" 2>/dev/null \
      || echo "go1.24.3")
    log_status "Installing $_ver to $_go_root"
    curl -fsSL "https://go.dev/dl/$_ver.$_os-$_arch.tar.gz" | tar -C "$HOME/.local" -xz
  fi
fi
